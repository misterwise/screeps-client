VITE_PROXY_TARGET=http://localhost:21025

# Optional: set to your external hostname when serving behind an HTTPS reverse proxy
# (e.g. "tailscale serve 5173" exposes the dev server via your Tailscale hostname)
# This makes Vite's HMR WebSocket connect via wss:// on the proxy port instead of
# Vite's own port, so hot-reload works on mobile devices too.
#
# VITE_HOST=your-machine.tailnet.ts.net
# VITE_HOST_PORT=443   # default, only needed if your proxy uses a non-standard port
