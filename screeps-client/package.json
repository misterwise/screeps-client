{
  "name": "screeps-client",
  "version": "0.10.0",
  "license": "ISC",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bastianh/screeps-client.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:bundle": "tsc && vite build --config vite-singlefile.config.ts",
    "build:embedded": "tsc && VITE_BASE=/client/ VITE_EMBEDDED=true VITE_OUT_DIR=dist/embedded vite build",
    "build:embedded:xxscreeps": "tsc && VITE_BASE=./ VITE_EMBEDDED=true VITE_XXSCREEPS=true VITE_OUT_DIR=dist/xxscreeps-mod vite build",
    "build:all": "pnpm build && pnpm build:embedded && pnpm build:embedded:xxscreeps",
    "preview": "vite preview",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build:all && node ../scripts/strip-client-devdeps.mjs"
  },
  "devDependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@eslint/js": "^10.0.1",
    "@solid-devtools/debugger": "^0.28.1",
    "codemirror": "^6.0.2",
    "eslint": "^9.0.0",
    "eslint-plugin-solid": "^0.14.0",
    "globals": "^17.6.0",
    "https-proxy-agent": "^9.0.0",
    "jsdom": "^29.1.1",
    "lucide-solid": "^0.513.0",
    "pixi.js": "^8.9.0",
    "screeps-connectivity": "workspace:*",
    "solid-codemirror": "^2.3.3",
    "solid-devtools": "^0.34.5",
    "solid-js": "^1.9.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.6"
  }
}
