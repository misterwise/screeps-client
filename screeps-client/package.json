{
  "name": "@bastianh/screeps-client",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bastianh/screeps-client.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:bundle": "tsc && vite build --config vite-singlefile.config.ts",
    "preview": "vite preview",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bastianh/screeps-connectivity": "workspace:*",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "codemirror": "^6.0.2",
    "pixi.js": "^8.9.0",
    "solid-codemirror": "^2.3.3",
    "solid-js": "^1.9.0",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@solid-devtools/debugger": "^0.28.1",
    "eslint": "^9.0.0",
    "eslint-plugin-solid": "^0.14.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "solid-devtools": "^0.34.5",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.6"
  }
}
