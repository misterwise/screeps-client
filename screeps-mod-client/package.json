{
  "name": "screepsmod-client-new",
  "version": "0.1.2",
  "description": "Screeps server mod that serves the screeps-client at /client and connects it to the same server.",
  "type": "commonjs",
  "main": "index.js",
  "files": [
    "index.js",
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bastianh/screeps-client.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "pnpm --filter screeps-client build:embedded && node ./scripts/copy-dist.js",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.18.0"
  }
}
